# ETECÉ STUDIO — environment variables
# Copy this file to `.env.local` and fill in the values, then restart: npm run dev

# Supabase project URL (Settings → API → Project URL).
# Safe to expose to the client via NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (Settings → API → service_role).
# SERVER-SIDE ONLY — use only in API routes and server components.
# Never expose in client components or commit real values.
SUPABASE_SERVICE_ROLE_KEY=
